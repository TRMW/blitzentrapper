# Copy to .env and set values. .env is gitignored.
# Use the Neon connection string for the dev/staging database.
# Get it from Neon Console → your project → branch → Connect.
#
# For the app: pooled URL is fine (host contains -pooler).
# For migrations: if you see PG::InFailedSqlTransaction, use the direct
# (non-pooled) connection string instead.
DATABASE_URL=
